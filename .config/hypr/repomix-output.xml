local mainMod = "SUPER"
package.path = package.path .. ";" .. os.getenv("HOME") .. "/.config/hypr/plugins/?.lua"

local smw = require("plugins.split-monitor-workspaces")

smw.setup({
	workspace_count = 10, -- Number of workspaces per monitor
	keep_focused = true, -- Keep focus on current monitor when switching
	enable_notifications = false, -- Disable notifications
	enable_persistent_workspaces = true, -- Create workspaces at startup
})

for i = 1, smw.get_amount_of_workspaces() do
	local n = tostring(i)
	if n == "10" then
		n = "0"
	end -- Map workspace 10 to key 0

	-- Switch to workspace N on the currently focused monitor
	hl.bind(mainMod .. " + " .. n, smw.workspace(n))

	-- Move window to workspace N silently (no focus change)
	hl.bind(mainMod .. " + SHIFT + " .. n, smw.move_to_workspace_silent(n))
end
</file>

